            ],
            "Germany": [
                "https://ftp.fau.de/archlinux/$repo/os/$arch",
                "https://ftp.halifax.rwth-aachen.de/archlinux/$repo/os/$arch",
                "https://mirror.fra10.de.leaseweb.net/archlinux/$repo/os/$arch"
            ],
            "Belgium": [
                "https://mirror.1ago.be/archlinux/$repo/os/$arch"
            ],
            "Denmark": [
                "https://mirrors.dotsrc.org/archlinux/$repo/os/$arch",
                "https://mirror.group.one/archlinux/$repo/os/$arch"
            ],
            "Sweden": [
                "https://mirror.bahnhof.net/pub/archlinux/$repo/os/$arch",
                "https://ftp.lysator.liu.se/pub/archlinux/$repo/os/$arch",
                "https://mirror.accum.se/mirror/archlinux/$repo/os/$arch"
            ],
            "Finland": [
                "https://mirror.5i.fi/archlinux/$repo/os/$arch",
                "https://mirror.srv.fail/archlinux/$repo/os/$arch"
            ]
        }
